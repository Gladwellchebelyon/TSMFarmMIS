generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]

  // Farms managed by this user
  farms Farm[]
}

model Farm {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  location    String
  acreage     Float
  description String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Farm Manager
  managerId   Int
  manager     User     @relation(fields: [managerId], references: [id])
}

model ActivityLog {
  id          Int            @id @default(autoincrement())

  action      String
  module      String
  description String

  severity    Severity       @default(INFO)
  status      ActivityStatus @default(SUCCESS)

  comment     String?

  ipAddress   String?
  device      String?

  createdAt   DateTime       @default(now())

  userId      Int
  user        User           @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  SUPERVISOR
  STOREKEEPER
  ACCOUNTANT
}

enum Severity {
  INFO
  NOTICE
  WARNING
  CRITICAL
}

enum ActivityStatus {
  SUCCESS
  FAILED
  PENDING
}

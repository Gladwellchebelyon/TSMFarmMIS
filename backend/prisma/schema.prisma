generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  fullName    String
  email       String   @unique
  
  password    String
  role        Role
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  SUPERVISOR
  STOREKEEPER
  ACCOUNTANT
}
